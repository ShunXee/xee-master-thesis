@inproceedings{BEFD,
author = {Zhang, Mo and Yu, Fei and Zhao, Jie and Zhang, Li and Li, Quanzheng},
title = {BEFD: Boundary Enhancement and Feature Denoising for Vessel Segmentation},
year = {2020},
isbn = {978-3-030-59721-4},
